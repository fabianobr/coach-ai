# ─── LLM Provider Configuration ───────────────────────────────────────────────
# Choose one provider: anthropic | openai | ollama | gemini
LLM_PROVIDER=anthropic

# Model name (leave blank to use the default for the chosen provider)
# Defaults: anthropic=claude-haiku-4-5-20251001 | openai=gpt-4o-mini
#           ollama=llama3.2 | gemini=gemini-2.0-flash
LLM_MODEL=

# API key — generic override (takes precedence over provider-specific keys below)
LLM_API_KEY=

# Generation settings
LLM_MAX_TOKENS=2048
LLM_TEMPERATURE=0.7

# Base URL override — useful for Ollama or OpenAI-compatible proxies
# Ollama default: http://localhost:11434/v1
LLM_BASE_URL=

# ─── Provider-specific API keys (fallback if LLM_API_KEY is not set) ──────────
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GOOGLE_API_KEY=
